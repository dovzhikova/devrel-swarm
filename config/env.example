# PostHog Configuration
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_PROJECT_ID=your_posthog_project_id_here

# Product Configuration (retarget by changing these)
PRODUCT_NAME=OpenClaw
PRODUCT_URL=https://openclaw.ai
SALES_CTA_URL=https://calendly.com/your-name/15-minute-meeting
COMMUNITY_URL=

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=openclaw/openclaw

# Search Configuration (Firecrawl primary, Brave fallback)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
BRAVE_API_KEY=your_brave_api_key_here

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Logging Configuration
LOG_LEVEL=INFO

# Agent Configuration
AGENT_CONFIG_PATH=./config/agent_config.yaml
KNOWLEDGE_BASE_PATH=./knowledge_base

# Optional: Agent Settings
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Instantly AI Configuration
INSTANTLY_API_KEY=your_instantly_api_key_here

# Apollo.io Configuration
APOLLO_API_KEY=your_apollo_api_key_here

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email Notifications (Gmail app password)
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=you@gmail.com

# Google Sheets Content Calendar
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
SHEETS_ACCESS_TOKEN=your_oauth_token_here

# OpenAI (for Vox TTS)
OPENAI_API_KEY=your_openai_api_key_here
